API_HOST=0.0.0.0
API_PORT=8000
AEROTRACK_MODEL_PATH=yolov8n.pt
AEROTRACK_MODEL_URL=https://example.com/path/to/aerotrack-detector.pt
AEROTRACK_DEVICE=cpu
AEROTRACK_CONFIDENCE=0.25
AEROTRACK_IOU=0.45
AEROTRACK_PREDICT_IMGSZ=384
AEROTRACK_TRACK_MAX_FRAMES=2
